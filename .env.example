# Copia este archivo como .env y completa los valores reales
# NUNCA subas .env al repositorio (está en .gitignore)

PORT=3000
JWT_SECRET=genera-un-secreto-largo-y-aleatorio-aqui
LOG_LEVEL=info
NODE_ENV=development

# PostgreSQL — usar el rol techfix_app (no postgres superusuario)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nombre_de_tu_base_de_datos
DB_USER=techfix_app
DB_PASSWORD=cambia-esta-contrasena-en-produccion
